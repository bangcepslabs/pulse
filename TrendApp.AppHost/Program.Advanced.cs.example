// Advanced Aspire Configuration Examples
// 이 파일은 참고용 예시입니다. Program.cs에 필요한 부분만 복사하여 사용하세요.

using Aspire.Hosting;

var builder = DistributedApplication.CreateBuilder(args);

// ============================================
// 예시 1: Python Backend (기본 설정)
// ============================================
var pythonBackend = builder.AddExecutable(
    name: "python-backend",
    command: "python",
    workingDirectory: "../backend",
    args: ["main.py"]
)
.WithHttpEndpoint(port: 8000, name: "api")
.WithEnvironment("PYTHONUNBUFFERED", "1");

// ============================================
// 예시 2: 환경 변수 추가
// ============================================
var pythonBackendWithEnv = builder.AddExecutable(
    name: "python-backend",
    command: "python",
    workingDirectory: "../backend",
    args: ["main.py"]
)
.WithHttpEndpoint(port: 8000, name: "api")
.WithEnvironment("PYTHONUNBUFFERED", "1")
.WithEnvironment("OLLAMA_HOST", "http://localhost:11434")
.WithEnvironment("LOG_LEVEL", "DEBUG")
.WithEnvironment("DATABASE_PATH", "trends.db");

// ============================================
// 예시 3: Ollama 서버도 Aspire로 관리
// ============================================
var ollama = builder.AddExecutable(
    name: "ollama",
    command: "ollama",
    workingDirectory: "..",
    args: ["serve"]
)
.WithHttpEndpoint(port: 11434, name: "ollama-api")
.WithEnvironment("OLLAMA_HOST", "0.0.0.0:11434");

// Python이 Ollama에 의존
var pythonWithOllama = builder.AddExecutable(
    name: "python-backend",
    command: "python",
    workingDirectory: "../backend",
    args: ["main.py"]
)
.WithHttpEndpoint(port: 8000, name: "api")
.WithEnvironment("PYTHONUNBUFFERED", "1")
.WithReference(ollama)  // Ollama가 먼저 시작되도록
.WaitFor(ollama);  // Ollama가 준비될 때까지 대기

// ============================================
// 예시 4: Redis 캐싱 추가 (향후 확장)
// ============================================
var redis = builder.AddRedis("cache")
    .WithRedisCommander();  // Redis Commander UI 자동 추가

var pythonWithRedis = builder.AddExecutable(
    name: "python-backend",
    command: "python",
    workingDirectory: "../backend",
    args: ["main.py"]
)
.WithHttpEndpoint(port: 8000, name: "api")
.WithReference(redis)  // Redis 연결 정보 자동 주입
.WithEnvironment("PYTHONUNBUFFERED", "1");

// ============================================
// 예시 5: PostgreSQL 데이터베이스 (SQLite 대신)
// ============================================
var postgres = builder.AddPostgres("trends-db")
    .WithPgAdmin()  // PgAdmin UI 자동 추가
    .AddDatabase("trendsdb");

var pythonWithPostgres = builder.AddExecutable(
    name: "python-backend",
    command: "python",
    workingDirectory: "../backend",
    args: ["main.py"]
)
.WithHttpEndpoint(port: 8000, name: "api")
.WithReference(postgres)  // PostgreSQL 연결 정보 자동 주입
.WithEnvironment("PYTHONUNBUFFERED", "1");

// ============================================
// 예시 6: 여러 Worker 프로세스
// ============================================

// RSS Scraper Worker (독립 실행)
var scraperWorker = builder.AddExecutable(
    name: "scraper-worker",
    command: "python",
    workingDirectory: "../backend",
    args: ["worker_scraper.py"]  // 별도 워커 파일
)
.WithEnvironment("PYTHONUNBUFFERED", "1")
.WithEnvironment("WORKER_TYPE", "scraper");

// Ollama Processor Worker (독립 실행)
var processorWorker = builder.AddExecutable(
    name: "processor-worker",
    command: "python",
    workingDirectory: "../backend",
    args: ["worker_processor.py"]  // 별도 워커 파일
)
.WithEnvironment("PYTHONUNBUFFERED", "1")
.WithEnvironment("WORKER_TYPE", "processor");

// API Server (메인)
var apiServer = builder.AddExecutable(
    name: "api-server",
    command: "python",
    workingDirectory: "../backend",
    args: ["api_server.py"]  // API만 담당
)
.WithHttpEndpoint(port: 8000, name: "api")
.WithEnvironment("PYTHONUNBUFFERED", "1");

// ============================================
// 예시 7: Container 이미지 사용 (Docker)
// ============================================

// Python Backend를 Docker 컨테이너로 실행
var pythonContainer = builder.AddContainer(
    name: "python-backend-container",
    image: "trend-backend",
    tag: "latest"
)
.WithHttpEndpoint(port: 8000, targetPort: 8000, name: "api")
.WithVolume("../backend", "/app")
.WithEnvironment("PYTHONUNBUFFERED", "1");

// ============================================
// 예시 8: Health Check 추가
// ============================================
var pythonWithHealthCheck = builder.AddExecutable(
    name: "python-backend",
    command: "python",
    workingDirectory: "../backend",
    args: ["main.py"]
)
.WithHttpEndpoint(port: 8000, name: "api")
.WithEnvironment("PYTHONUNBUFFERED", "1")
.WithHttpHealthCheck(
    endpoint: "/",  // Health check 엔드포인트
    port: 8000
);

// ============================================
// 예시 9: 개발/프로덕션 환경 분리
// ============================================
var isDevelopment = builder.Environment.IsDevelopment();

var pythonEnvAware = builder.AddExecutable(
    name: "python-backend",
    command: "python",
    workingDirectory: "../backend",
    args: ["main.py"]
)
.WithHttpEndpoint(port: 8000, name: "api")
.WithEnvironment("PYTHONUNBUFFERED", "1")
.WithEnvironment("ENVIRONMENT", isDevelopment ? "development" : "production")
.WithEnvironment("LOG_LEVEL", isDevelopment ? "DEBUG" : "INFO");

// ============================================
// 예시 10: 여러 RSS 소스를 위한 Multiple Backends
// ============================================
var yahooBackend = builder.AddExecutable(
    name: "backend-yahoo",
    command: "python",
    workingDirectory: "../backend",
    args: ["main.py"]
)
.WithHttpEndpoint(port: 8001, name: "api-yahoo")
.WithEnvironment("RSS_SOURCE", "yahoo");

var bloombergBackend = builder.AddExecutable(
    name: "backend-bloomberg",
    command: "python",
    workingDirectory: "../backend",
    args: ["main.py"]
)
.WithHttpEndpoint(port: 8002, name: "api-bloomberg")
.WithEnvironment("RSS_SOURCE", "bloomberg");

// ============================================
// 예시 11: Prometheus + Grafana 모니터링
// ============================================
var prometheus = builder.AddContainer("prometheus", "prom/prometheus")
    .WithBindMount("../monitoring/prometheus.yml", "/etc/prometheus/prometheus.yml")
    .WithHttpEndpoint(port: 9090, name: "prometheus-ui");

var grafana = builder.AddContainer("grafana", "grafana/grafana")
    .WithHttpEndpoint(port: 3000, name: "grafana-ui")
    .WithEnvironment("GF_SECURITY_ADMIN_PASSWORD", "admin");

// ============================================
// 최종 빌드 및 실행
// ============================================
var app = builder.Build();
await app.RunAsync();


// ============================================
// 사용 가이드:
// ============================================
// 1. 기본 설정: 예시 1 사용
// 2. 환경 변수 추가: 예시 2 참고
// 3. Ollama 관리: 예시 3 사용
// 4. Redis 캐싱: 예시 4 사용 (redis 패키지 설치 필요)
// 5. PostgreSQL: 예시 5 사용 (postgresql 패키지 설치 필요)
// 6. 마이크로서비스: 예시 6 참고
// 7. Docker 사용: 예시 7 참고 (Dockerfile 필요)
// 8. Health Check: 예시 8 참고
// 9. 환경별 설정: 예시 9 참고
// 10. 다중 소스: 예시 10 참고
// 11. 모니터링: 예시 11 참고

// ============================================
// 필요한 NuGet 패키지:
// ============================================
// dotnet add package Aspire.Hosting.Redis
// dotnet add package Aspire.Hosting.PostgreSQL
// dotnet add package Aspire.Hosting.Docker
